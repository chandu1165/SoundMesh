# Free local AI. Install Ollama, then run:
#   ollama pull llama3.2:3b
AI_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Free local persistence. Use json for simple files or sqlite for one local DB file.
AURALYZE_STORAGE=json

# Free hosted stem fallback safety limit. Set 0 for no limit on your own machine.
AURALYZE_FALLBACK_MAX_SECONDS=180

# Optional paid model provider. Leave disabled for the free/open-source setup.
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4.1-mini

# Optional commercial checkout. Leave disabled for the free/open-source setup.
# STRIPE_SECRET_KEY=sk_test_your_stripe_key
# STRIPE_PRICE_PRO=price_your_pro_price_id
# STRIPE_PRICE_STUDIO=price_your_studio_price_id
# Optional if ffmpeg is not on PATH:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# Optional if demucs is not on PATH:
# DEMUCS_COMMAND=python -m demucs
# DEMUCS_MODEL=htdemucs
